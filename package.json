{
	"name": "rspress-plugin-third-parties",
	"version": "1.0.0",
	"description": "Optimized third-party components (YouTube, Google Maps, GA) and script loading strategies for Rspress.",
	"scripts": {
		"dev": "rslib build --watch",
		"build": "rslib build",
		"format": "biome format --write .",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"release": "pnpm build && changeset publish",
		"deploy:demo": "pnpm build && pnpm --filter rspress-plugin-demo build && gh-pages -d examples/demo/doc_build -m 'deploy: demo site'"
	},
	"keywords": [
		"rspress",
		"rspress-plugin",
		"react",
		"analytics",
		"google-analytics",
		"youtube",
		"embed",
		"performance"
	],
	"author": {
		"name": "Sanjaiyan Parthipan",
		"url": "https://github.com/sanjaiyan-dev"
	},
	"license": "MIT",
	"homepage": "https://github.com/sanjaiyan-dev/rspress-plugin-third-parties#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/sanjaiyan-dev/rspress-plugin-third-parties.git"
	},
	"bugs": {
		"url": "https://github.com/sanjaiyan-dev/rspress-plugin-third-parties/issues"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.cjs"
			}
		},
		"./plugin": {
			"import": {
				"types": "./dist/plugin.d.ts",
				"default": "./dist/plugin.js"
			},
			"require": {
				"types": "./dist/plugin.d.ts",
				"default": "./dist/plugin.cjs"
			}
		}
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@changesets/cli": "^2.31.1",
		"@rsbuild/plugin-react": "^2.1.0",
		"@rslib/core": "^0.23.2",
		"@rspress/core": "^2.0.18",
		"@rspress/shared": "^2.0.18",
		"@types/node": "^26.1.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"babel-plugin-react-compiler": "^1.0.0",
		"gh-pages": "^6.3.0",
		"react": "^19.2.8",
		"react-dom": "^19.2.8",
		"typescript": "^7.0.2"
	},
	"peerDependencies": {
		"@rspress/core": ">=2.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"dependencies": {
		"react-compiler-runtime": "0.0.0-experimental-a1856f3-20260507",
		"third-party-capital": "^3.0.0"
	},
	"packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
